{
  "name": "invoicestogo",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --experimental-sqlite server/index.js",
    "client": "npm --prefix client run dev",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
